@page
@model BookStoreSample.Pages.Admin.Inventory.IndexModel
@{
    ViewData["Title"] = "库存流水";
    var pageNumbers = Enumerable.Range(1, Model.TotalPages)
        .Where(page => page == 1 || page == Model.TotalPages || Math.Abs(page - Model.CurrentPageNumber) <= 2)
        .ToList();
}

<section class="admin-panel admin-panel-plain">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Inventory</span>
            <h1 class="section-title">库存流水</h1>
        </div>
        <div class="admin-actions">
            <a class="ghost-button" asp-page="/Admin/Index">后台看板</a>
            <a class="ghost-button" asp-page="/Admin/Products/Index">商品管理</a>
        </div>
    </div>

    <div class="admin-list-summary">
        <span>共 @Model.TotalCount 条库存记录</span>
        @if (Model.TotalCount > 0)
        {
            <span>当前显示 @Model.StartItem - @Model.EndItem</span>
        }
    </div>

    @if (Model.Logs.Count == 0)
    {
        <div class="tool-row empty-state">暂无库存变更记录。</div>
    }
    else
    {
        <table class="admin-table">
            <thead>
            <tr>
                <th>时间</th>
                <th>图书</th>
                <th>类型</th>
                <th>变更</th>
                <th>库存</th>
                <th>关联订单</th>
                <th>操作人</th>
                <th>说明</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <td>@log.ChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a asp-page="/Admin/Products/Edit" asp-route-id="@log.ProductId">@log.ProductTitle</a>
                    </td>
                    <td>@DisplayType(log.ChangeType)</td>
                    <td class="@(log.QuantityChanged < 0 ? "stock-negative" : "stock-positive")">
                        @(log.QuantityChanged > 0 ? "+" : "")@log.QuantityChanged
                    </td>
                    <td>@log.QuantityBefore -> @log.QuantityAfter</td>
                    <td>
                        @if (log.OrderId is not null)
                        {
                            <a asp-page="/Orders/Details" asp-route-id="@log.OrderId">#@log.OrderId</a>
                        }
                        else
                        {
                            <span class="muted-text">-</span>
                        }
                    </td>
                    <td>@log.ChangedBy</td>
                    <td>@log.Note</td>
                </tr>
            }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav class="admin-pagination" aria-label="库存流水分页导航">
                <a class="pagination-link @(Model.CurrentPageNumber <= 1 ? "is-disabled" : string.Empty)"
                   asp-page="/Admin/Inventory/Index"
                   asp-route-currentPage="@(Model.CurrentPageNumber - 1)">上一页</a>

                <div class="pagination-pages">
                    @for (var i = 0; i < pageNumbers.Count; i++)
                    {
                        if (i > 0 && pageNumbers[i] - pageNumbers[i - 1] > 1)
                        {
                            <span class="pagination-ellipsis">…</span>
                        }

                        var pageNumber = pageNumbers[i];
                        <a class="pagination-link @(pageNumber == Model.CurrentPageNumber ? "is-current" : string.Empty)"
                           asp-page="/Admin/Inventory/Index"
                           asp-route-currentPage="@pageNumber">@pageNumber</a>
                    }
                </div>

                <a class="pagination-link @(Model.CurrentPageNumber >= Model.TotalPages ? "is-disabled" : string.Empty)"
                   asp-page="/Admin/Inventory/Index"
                   asp-route-currentPage="@(Model.CurrentPageNumber + 1)">下一页</a>
            </nav>
        }
    }
</section>

@functions {
    private static string DisplayType(string type) => type switch
    {
        "OrderCreated" => "下单扣减",
        "OrderCancelled" => "取消回滚",
        "AdminAdjustment" => "后台调整",
        _ => type
    };
}

<style>
    .admin-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .admin-list-summary {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    .stock-negative {
        color: var(--accent-strong);
        font-weight: 700;
    }

    .stock-positive {
        color: var(--forest);
        font-weight: 700;
    }

    .muted-text {
        color: var(--muted);
    }

    .admin-pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
    }

    .pagination-pages {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .pagination-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.4rem;
        min-height: 2.4rem;
        padding: 0.45rem 0.7rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
        background: rgba(255, 253, 249, 0.7);
        font-weight: 600;
    }

    .pagination-link.is-current {
        background: var(--ink);
        color: #fff8f2;
        border-color: var(--ink);
    }

    .pagination-link.is-disabled {
        pointer-events: none;
        opacity: 0.45;
    }

    .pagination-ellipsis {
        color: var(--muted);
        padding: 0 0.2rem;
    }
</style>
