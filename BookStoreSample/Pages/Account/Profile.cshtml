@page
@model BookStoreSample.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "编辑资料";
    var avatarInitial = Model.Input.DisplayName.FirstOrDefault();
}

<section class="profile-shell">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Profile</span>
            <h1 class="section-title">编辑资料</h1>
        </div>
        <a asp-page="/Account/Index" class="ghost-button">返回个人中心</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert @Model.MessageType">@Model.Message</div>
    }

    <form method="post" enctype="multipart/form-data" class="profile-form">
        <div class="avatar-editor">
            <div class="avatar-preview">
                @if (!string.IsNullOrWhiteSpace(Model.CurrentAvatarUrl))
                {
                    <img src="@Model.CurrentAvatarUrl" alt="当前头像" />
                }
                else
                {
                    <span>@(avatarInitial == default ? 'U' : avatarInitial)</span>
                }
            </div>
            <div class="avatar-copy">
                <label asp-for="Input.Avatar"></label>
                <input class="editorial-input" asp-for="Input.Avatar" type="file" accept="image/*" />
                <small>支持 JPG、PNG、WEBP、GIF，图片大小不超过 2MB。</small>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Input.DisplayName"></label>
            <input class="editorial-input" asp-for="Input.DisplayName" maxlength="40" />
            <span asp-validation-for="Input.DisplayName" class="validation-message"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.Email"></label>
            <input class="editorial-input" asp-for="Input.Email" maxlength="120" />
            <span asp-validation-for="Input.Email" class="validation-message"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.PhoneNumber"></label>
            <input class="editorial-input" asp-for="Input.PhoneNumber" maxlength="30" />
            <span asp-validation-for="Input.PhoneNumber" class="validation-message"></span>
        </div>
        <div class="profile-actions">
            <button type="submit" class="primary-button">保存资料</button>
            <a asp-page="/Account/Index" class="ghost-button">取消</a>
        </div>
    </form>
</section>

<style>
.profile-shell {
    display: grid;
    gap: 1.25rem;
    max-width: 760px;
}

.profile-form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 253, 249, 0.62);
}

.avatar-editor {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
}

.avatar-preview {
    width: 96px;
    aspect-ratio: 1;
    border-radius: 8px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: var(--ink);
    color: #fff8f2;
    font-size: 2rem;
    font-weight: 800;
}

.avatar-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.avatar-copy {
    display: grid;
    gap: 0.5rem;
}

.avatar-copy small {
    color: var(--muted);
    line-height: 1.6;
}

.profile-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
}

.validation-message {
    color: var(--accent);
    font-size: 0.85rem;
}

@@media (max-width: 640px) {
    .avatar-editor {
        grid-template-columns: 1fr;
    }
}
</style>
