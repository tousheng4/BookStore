@page
@model BookStoreSample.Pages.Admin.Products.IndexModel
@{
    ViewData["Title"] = "后台商品管理";
    var pageNumbers = Enumerable.Range(1, Model.TotalPages)
        .Where(page => page == 1 || page == Model.TotalPages || Math.Abs(page - Model.CurrentPageNumber) <= 2)
        .ToList();
}

<section class="admin-panel admin-panel-plain">
    <div class="section-heading">
        <div>
            <span class="section-kicker">商品管理</span>
            <h1 class="section-title">商品管理</h1>
        </div>
        <div class="admin-actions">
            <a class="ghost-button" asp-page="/Admin/Index">后台看板</a>
            <a class="primary-button" asp-page="/Admin/Products/Create">新增图书</a>
        </div>
    </div>

    <div class="admin-list-summary">
        <span>共 @Model.TotalCount 本图书</span>
        @if (Model.TotalCount > 0)
        {
            <span>当前显示 @Model.StartItem - @Model.EndItem</span>
        }
    </div>

    <table class="admin-table">
        <thead>
        <tr>
            <th>ID</th>
            <th>书名</th>
            <th>作者</th>
            <th>分类</th>
            <th>价格</th>
            <th>库存</th>
            <th>状态</th>
            <th>操作</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Title</td>
                <td>@product.Author</td>
                <td>@product.Category</td>
                <td>￥@product.Price.ToString("0.00")</td>
                <td>
                    @if (product.Stock <= 5)
                    {
                        <span class="low-stock-pill">库存 @product.Stock</span>
                    }
                    else
                    {
                        <span>@product.Stock</span>
                    }
                </td>
                <td>
                    <span class="status-pill @(product.IsActive ? "status-active" : "status-inactive")">
                        @(product.IsActive ? "上架中" : "已下架")
                    </span>
                </td>
                <td class="inline-actions">
                    <a class="ghost-button" asp-page="/Admin/Products/Edit" asp-route-id="@product.Id">编辑</a>
                    <form method="post" asp-page-handler="ToggleActive" asp-route-id="@product.Id" asp-route-currentPage="@Model.CurrentPageNumber" class="inline-form">
                        <button type="submit" class="ghost-button">@(product.IsActive ? "下架" : "上架")</button>
                    </form>
                    <a class="danger-button" asp-page="/Admin/Products/Delete" asp-route-id="@product.Id">删除</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav class="admin-pagination" aria-label="商品分页导航">
            <a class="pagination-link @(Model.CurrentPageNumber <= 1 ? "is-disabled" : string.Empty)"
               asp-page="/Admin/Products/Index"
               asp-route-currentPage="@(Model.CurrentPageNumber - 1)">上一页</a>

            <div class="pagination-pages">
                @for (var i = 0; i < pageNumbers.Count; i++)
                {
                    if (i > 0 && pageNumbers[i] - pageNumbers[i - 1] > 1)
                    {
                        <span class="pagination-ellipsis">…</span>
                    }

                    var pageNumber = pageNumbers[i];
                    <a class="pagination-link @(pageNumber == Model.CurrentPageNumber ? "is-current" : string.Empty)"
                       asp-page="/Admin/Products/Index"
                       asp-route-currentPage="@pageNumber">@pageNumber</a>
                }
            </div>

            <a class="pagination-link @(Model.CurrentPageNumber >= Model.TotalPages ? "is-disabled" : string.Empty)"
               asp-page="/Admin/Products/Index"
               asp-route-currentPage="@(Model.CurrentPageNumber + 1)">下一页</a>
        </nav>
    }
</section>

<style>
    .admin-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .admin-list-summary {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    .low-stock-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 8px;
        padding: 0.25rem 0.55rem;
        background: rgba(141, 43, 39, 0.1);
        color: var(--accent-strong);
        font-weight: 600;
    }

    .inline-form {
        margin: 0;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 8px;
        padding: 0.25rem 0.55rem;
        font-weight: 600;
    }

    .status-active {
        background: rgba(37, 72, 63, 0.1);
        color: var(--forest);
    }

    .status-inactive {
        background: rgba(99, 87, 77, 0.12);
        color: var(--muted);
    }

    .admin-pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
    }

    .pagination-pages {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .pagination-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.4rem;
        min-height: 2.4rem;
        padding: 0.45rem 0.7rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
        background: rgba(255, 253, 249, 0.7);
        font-weight: 600;
    }

    .pagination-link.is-current {
        background: var(--ink);
        color: #fff8f2;
        border-color: var(--ink);
    }

    .pagination-link.is-disabled {
        pointer-events: none;
        opacity: 0.45;
    }

    .pagination-ellipsis {
        color: var(--muted);
        padding: 0 0.2rem;
    }
</style>
