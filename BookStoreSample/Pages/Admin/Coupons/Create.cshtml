@page
@model BookStoreSample.Pages.Admin.Coupons.CreateModel
@{
    ViewData["Title"] = "新增优惠券";
}

<section class="admin-panel admin-panel-plain">
    <div class="section-heading">
        <div>
            <span class="section-kicker">营销工具</span>
            <h1 class="section-title">新增优惠券</h1>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p class="alert error">@Model.Message</p>
    }

    <form method="post" class="coupon-form">
        <div class="form-row">
            <div class="form-field">
                <label asp-for="Input.Name"></label>
                <input class="editorial-input" asp-for="Input.Name" placeholder="例如 全场满减券" />
            </div>
            <div class="form-field">
                <label asp-for="Input.Code"></label>
                <input class="editorial-input" asp-for="Input.Code" placeholder="例如 SUMMER20" style="text-transform: uppercase" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label asp-for="Input.MinimumAmount"></label>
                <input class="editorial-input" type="number" step="0.01" min="0" asp-for="Input.MinimumAmount" placeholder="满多少可用，填 0 表示无门槛" />
            </div>
            <div class="form-field">
                <label asp-for="Input.DiscountAmount"></label>
                <input class="editorial-input" type="number" step="0.01" min="0" asp-for="Input.DiscountAmount" placeholder="优惠金额" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label asp-for="Input.StartsAt"></label>
                <input class="editorial-input" type="datetime-local" asp-for="Input.StartsAt" />
            </div>
            <div class="form-field">
                <label asp-for="Input.EndsAt"></label>
                <input class="editorial-input" type="datetime-local" asp-for="Input.EndsAt" />
            </div>
        </div>

        <div class="form-field">
            <label class="checkbox-label">
                <input type="checkbox" asp-for="Input.IsActive" />
                <span>立即生效</span>
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-button">保存优惠券</button>
            <a class="ghost-button" asp-page="/Admin/Coupons/Index">取消</a>
        </div>
    </form>
</section>

<style>
    .coupon-form { display: grid; gap: 1.25rem; max-width: 680px; }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-field {
        display: grid;
        gap: 0.4rem;
    }

    .form-field label {
        font-size: 0.86rem;
        font-weight: 600;
        color: var(--muted);
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.9rem;
    }

    .form-actions {
        display: flex;
        gap: 0.75rem;
        padding-top: 0.5rem;
    }
</style>
