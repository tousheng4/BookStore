@page
@model BookStoreSample.Pages.Account.WishlistModel
@{
    ViewData["Title"] = "我的收藏";
}

<div class="page-shell">
    <h2>我的收藏</h2>

    @if (Model.Items.Count == 0)
    {
        <p class="muted-text">暂无收藏图书，去 <a asp-page="/Products/Index">逛逛书店</a> 吧。</p>
    }
    else
    {
        <div class="book-grid">
            @foreach (var item in Model.Items)
            {
                var product = item.Product;
                if (product is null) continue;
                <article class="book-card">
                    <a asp-page="/Products/Details" asp-route-id="@product.Id" class="book-cover-wrap">
                        <img src="@product.CoverUrl" alt="@product.Title" class="book-cover" loading="lazy" />
                    </a>
                    <div class="book-meta">
                        <h3 class="book-title">
                            <a asp-page="/Products/Details" asp-route-id="@product.Id">@product.Title</a>
                        </h3>
                        <p class="book-author">@product.Author</p>
                        <p class="book-price">￥@product.Price</p>
                        <div class="book-actions">
                            <form method="post" asp-page-handler="AddToCart" asp-route-productId="@product.Id" style="display:inline">
                                <button type="submit" class="primary-button small">加入购物车</button>
                            </form>
                            <form method="post" asp-page-handler="Remove" asp-route-productId="@product.Id" style="display:inline">
                                <button type="submit" class="ghost-button small danger">移除</button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }

    <div style="margin-top:1rem;">
        <a asp-page="/Products/Index" class="ghost-button">继续逛逛</a>
    </div>
</div>

<style>
    .muted-text { color: var(--muted); }
    .book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; margin: 1.5rem 0; align-items: start; }
    .book-card { display: flex; flex-direction: column; }
    .book-cover-wrap { display: block; overflow: hidden; border-radius: 2px; margin-bottom: 0.5rem; height: 240px; }
    .book-cover { width: 100%; height: 100%; object-fit: cover; transition: transform 0.2s; }
    .book-cover:hover { transform: scale(1.03); }
    .book-meta { display: grid; grid-template-rows: 2.6em auto auto auto; row-gap: 0.25rem; }
    .book-title { font-size: 0.95rem; font-weight: 600; margin: 0; line-height: 1.3; height: 2.6em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    .book-title a { color: var(--ink); text-decoration: none; }
    .book-title a:hover { color: var(--accent); }
    .book-author { font-size: 0.8rem; color: var(--muted); margin: 0; }
    .book-price { font-size: 1rem; font-weight: 700; color: var(--accent-strong); margin: 0; }
    .book-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: auto; }
    .small { padding: 0.3rem 0.7rem; font-size: 0.8rem; }
</style>
