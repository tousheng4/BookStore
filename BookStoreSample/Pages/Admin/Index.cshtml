@page
@model BookStoreSample.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "后台看板";
}

<section class="admin-dashboard">
    <div class="section-heading">
        <div>
            <span class="section-kicker">Dashboard</span>
            <h1 class="section-title">后台看板</h1>
        </div>
        <div class="dashboard-actions">
            <a class="ghost-button" asp-page="/Admin/Products/Index">商品管理</a>
            <a class="secondary-button" asp-page="/Orders/Index">订单管理</a>
            <a class="ghost-button" asp-page="/Admin/Reviews/Index">评价管理</a>
            <a class="ghost-button" asp-page="/Admin/Coupons/Index">优惠券管理</a>
            <a class="ghost-button" asp-page="/Admin/Inventory/Index">库存流水</a>
            <a class="primary-button" asp-page="/Admin/Products/Create">新增图书</a>
        </div>
    </div>

    <div class="metric-grid">
        <article class="metric-card">
            <span>图书数量</span>
            <strong>@Model.ProductCount</strong>
        </article>
        <article class="metric-card">
            <span>订单总数</span>
            <strong>@Model.OrderCount</strong>
        </article>
        <article class="metric-card metric-card-warn">
            <span>待发货</span>
            <strong>@Model.PendingShipmentCount</strong>
        </article>
        <article class="metric-card metric-card-warn">
            <span>低库存</span>
            <strong>@Model.LowStockCount</strong>
        </article>
        <article class="metric-card">
            <span>评价数量</span>
            <strong>@Model.ReviewCount</strong>
        </article>
        <article class="metric-card metric-card-warn">
            <span>低分评价</span>
            <strong>@Model.LowRatingReviewCount</strong>
        </article>
        <article class="metric-card">
            <span>优惠券领取</span>
            <strong>@Model.CouponClaimCount</strong>
        </article>
        <article class="metric-card">
            <span>优惠券使用</span>
            <strong>@Model.CouponUsedCount</strong>
        </article>
        <article class="metric-card">
            <span>优惠金额</span>
            <strong>&yen;@Model.CouponDiscountTotal.ToString("0.00")</strong>
        </article>
        <article class="metric-card">
            <span>已支付销售额</span>
            <strong>&yen;@Model.PaidRevenue.ToString("0.00")</strong>
        </article>
        <article class="metric-card">
            <span>已完成销售额</span>
            <strong>&yen;@Model.CompletedRevenue.ToString("0.00")</strong>
        </article>
    </div>

    <div class="chart-grid">
        <article class="chart-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Orders</span>
                    <h2>近 7 日订单数</h2>
                </div>
            </div>
            <div class="bar-chart">
                @foreach (var item in Model.DailyOrderChart)
                {
                    <div class="chart-row">
                        <span class="chart-label">@item.Label</span>
                        <div class="chart-track">
                            <span class="chart-bar" style="width:@item.Percent%"></span>
                        </div>
                        <strong>@item.DisplayValue</strong>
                    </div>
                }
            </div>
        </article>

        <article class="chart-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Revenue</span>
                    <h2>近 7 日销售额</h2>
                </div>
            </div>
            <div class="bar-chart">
                @foreach (var item in Model.DailySalesChart)
                {
                    <div class="chart-row">
                        <span class="chart-label">@item.Label</span>
                        <div class="chart-track">
                            <span class="chart-bar chart-bar-money" style="width:@item.Percent%"></span>
                        </div>
                        <strong>@item.DisplayValue</strong>
                    </div>
                }
            </div>
        </article>

        <article class="chart-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Category</span>
                    <h2>分类销售额</h2>
                </div>
            </div>
            @if (Model.CategorySalesChart.Count == 0)
            {
                <p class="panel-empty">暂无已支付销售数据。</p>
            }
            else
            {
                <div class="bar-chart">
                    @foreach (var item in Model.CategorySalesChart)
                    {
                        <div class="chart-row">
                            <span class="chart-label">@item.Label</span>
                            <div class="chart-track">
                                <span class="chart-bar chart-bar-category" style="width:@item.Percent%"></span>
                            </div>
                            <strong>@item.DisplayValue</strong>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="chart-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Ranking</span>
                    <h2>热销排行</h2>
                </div>
            </div>
            <div class="bar-chart">
                @foreach (var item in Model.BestsellerChart)
                {
                    <div class="chart-row">
                        <span class="chart-label">@item.Label</span>
                        <div class="chart-track">
                            <span class="chart-bar chart-bar-rank" style="width:@item.Percent%"></span>
                        </div>
                        <strong>@item.DisplayValue</strong>
                    </div>
                }
            </div>
        </article>
    </div>

    <div class="dashboard-grid">
        <article class="dashboard-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Stock</span>
                    <h2>库存提醒</h2>
                </div>
                <a asp-page="/Admin/Inventory/Index" class="ghost-button">查看流水</a>
            </div>

            @if (Model.LowStockProducts.Count == 0)
            {
                <p class="panel-empty">当前没有低库存图书。</p>
            }
            else
            {
                <div class="dashboard-list">
                    @foreach (var product in Model.LowStockProducts)
                    {
                        <div class="dashboard-list-row">
                            <div>
                                <strong>@product.Title</strong>
                                <span>@product.Author · @product.Category</span>
                            </div>
                            <a asp-page="/Admin/Products/Edit" asp-route-id="@product.Id" class="stock-pill">库存 @product.Stock</a>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="dashboard-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Orders</span>
                    <h2>最近订单</h2>
                </div>
                <a asp-page="/Orders/Index" class="ghost-button">查看全部</a>
            </div>

            @if (Model.RecentOrders.Count == 0)
            {
                <p class="panel-empty">暂无订单。</p>
            }
            else
            {
                <div class="dashboard-list">
                    @foreach (var order in Model.RecentOrders)
                    {
                        var firstItem = order.Items.FirstOrDefault();
                        <div class="dashboard-list-row">
                            <div>
                                <strong>订单 #@order.Id</strong>
                                <span>@(firstItem?.Title ?? "未命名图书") · @(order.User?.DisplayName ?? "未知用户")</span>
                            </div>
                            <a asp-page="/Orders/Details" asp-route-id="@order.Id" class="status-pill">@order.Status</a>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="dashboard-panel">
            <div class="panel-heading">
                <div>
                    <span class="section-kicker">Reviews</span>
                    <h2>低分评价</h2>
                </div>
                <a asp-page="/Admin/Reviews/Index" asp-route-rating="2" class="ghost-button">处理评价</a>
            </div>

            @if (Model.LowRatingReviews.Count == 0)
            {
                <p class="panel-empty">当前没有低分评价。</p>
            }
            else
            {
                <div class="dashboard-list">
                    @foreach (var review in Model.LowRatingReviews)
                    {
                        <div class="dashboard-list-row">
                            <div>
                                <strong>@(review.Product?.Title ?? "未知图书")</strong>
                                <span>@(review.User?.DisplayName ?? "读者") · @review.Rating 星 · @review.Content</span>
                            </div>
                            <a asp-page="/Products/Details" asp-route-id="@review.ProductId" class="status-pill">查看</a>
                        </div>
                    }
                </div>
            }
        </article>
    </div>
</section>

<style>
    .admin-dashboard {
        display: grid;
        gap: 1.5rem;
    }

    .dashboard-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .metric-grid,
    .chart-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1rem;
    }

    .metric-card,
    .chart-panel {
        display: grid;
        gap: 0.75rem;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(255, 253, 249, 0.66);
    }

    .metric-card span {
        color: var(--muted);
        font-size: 0.9rem;
    }

    .metric-card strong {
        font-size: 1.8rem;
        line-height: 1;
        color: var(--ink);
    }

    .metric-card-warn strong {
        color: var(--accent);
    }

    .bar-chart {
        display: grid;
        gap: 0.65rem;
    }

    .chart-row {
        display: grid;
        grid-template-columns: minmax(72px, 1fr) minmax(100px, 2.5fr) auto;
        align-items: center;
        gap: 0.6rem;
        min-width: 0;
    }

    .chart-label {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--muted);
        font-size: 0.86rem;
    }

    .chart-row strong {
        font-size: 0.86rem;
        white-space: nowrap;
    }

    .chart-track {
        height: 10px;
        overflow: hidden;
        border-radius: 8px;
        background: var(--paper-deep);
    }

    .chart-bar {
        display: block;
        height: 100%;
        min-width: 0;
        border-radius: 8px;
        background: var(--accent);
    }

    .chart-bar-money {
        background: var(--forest);
    }

    .chart-bar-category {
        background: #7a6f4d;
    }

    .chart-bar-rank {
        background: #8d5a3b;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
    }

    .dashboard-panel {
        display: grid;
        gap: 1rem;
        align-content: start;
        padding: 1.25rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(255, 253, 249, 0.58);
    }

    .panel-heading {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .panel-heading h2 {
        margin: 0.25rem 0 0;
        font-size: 1.2rem;
    }

    .dashboard-list {
        display: grid;
        gap: 0.8rem;
    }

    .dashboard-list-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid var(--line);
    }

    .dashboard-list-row:last-child {
        padding-bottom: 0;
        border-bottom: 0;
    }

    .dashboard-list-row div {
        display: grid;
        gap: 0.2rem;
        min-width: 0;
    }

    .dashboard-list-row strong {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dashboard-list-row span,
    .panel-empty {
        color: var(--muted);
        font-size: 0.9rem;
    }

    .stock-pill,
    .status-pill {
        white-space: nowrap;
        border-radius: 8px;
        padding: 0.35rem 0.65rem;
        background: var(--paper-deep);
        color: var(--accent-strong);
        font-size: 0.86rem;
    }

    @@media (max-width: 820px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 560px) {
        .chart-row {
            grid-template-columns: 1fr;
        }
    }
</style>
