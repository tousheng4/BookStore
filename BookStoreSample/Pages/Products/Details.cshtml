@page "{id:int}"
@model BookStoreSample.Pages.Products.DetailsModel
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "图书详情";
}

@if (Model.Product is null)
{
    <div class="alert error">未找到对应图书。</div>
}
else
{
    <section class="product-detail">
        <article class="detail-cover detail-cover-plain">
            <img src="@Model.Product.CoverUrl" alt="@Model.Product.Title" />
        </article>
        <article class="product-detail-copy">
            <div>
                <p class="book-tile-meta">@Model.Product.Category</p>
                <h1 class="detail-title">@Model.Product.Title</h1>
                <p class="detail-copy detail-lead">@Model.Product.Description</p>
            </div>
            <div class="detail-meta">
                <span>@Model.Product.Author</span>
                <span>@Model.Product.Publisher</span>
                <span>库存 @Model.Product.Stock</span>
                <span>@(Model.Product.IsActive ? "上架中" : "已下架")</span>
                <span>评分 @Model.ReviewSummary.AverageText (@Model.ReviewSummary.Count)</span>
            </div>
            <div class="purchase-strip">
                <span class="product-price">￥@Model.Product.Price.ToString("0.00")</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="alert @Model.MessageType">@Model.Message</div>
            }

            @if (Model.Product.IsActive)
            {
                <form method="post" class="purchase-form">
                    <input type="hidden" asp-for="Input.ProductId" />
                    <div class="purchase-form-row">
                        <label asp-for="Input.Quantity"></label>
                        <input class="editorial-input quantity-input" asp-for="Input.Quantity" type="number" min="1" />
                        <button type="submit" class="primary-button">加入购物袋</button>
                        <a asp-page="/Products/Index" class="ghost-button">返回书店</a>
                    </div>
                </form>
                <div class="wishlist-row">
                    <button type="button"
                            id="wishlist-toggle"
                            class="@(Model.IsInWishlist ? "secondary-button" : "ghost-button")"
                            onclick="toggleWishlist(@Model.Product.Id)">
                        @(Model.IsInWishlist ? "♥ 已收藏" : "♡ 收藏")
                    </button>
                    <a asp-page="/Account/Wishlist" class="ghost-button">查看收藏</a>
                </div>
            }
            else
            {
                <div class="alert error">这本书已下架，暂时不能购买。</div>
                <a asp-page="/Products/Index" class="ghost-button">返回书店</a>
            }
        </article>
    </section>

    <section class="qa-section">
        <div class="section-heading">
            <div>
                <span class="section-kicker">Q&A</span>
                <h2>读者问答</h2>
            </div>
            <span class="qa-count">@Model.Questions.Count 条问题</span>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form method="post" asp-page-handler="Question" asp-route-id="@Model.Product.Id" class="qa-form">
                <div class="form-field">
                    <label asp-for="Question.Content"></label>
                    <textarea class="editorial-textarea" asp-for="Question.Content" maxlength="500" placeholder="比如：这本书适合零基础吗？有没有配套案例？"></textarea>
                    <span asp-validation-for="Question.Content" class="field-validation-error"></span>
                </div>
                <button type="submit" class="primary-button">提交问题</button>
            </form>
        }
        else
        {
            <p class="review-hint">
                <a asp-page="/Account/Login" class="text-link">登录</a> 后可以向其他读者或管理员提问。
            </p>
        }

        @if (Model.Questions.Count == 0)
        {
            <p class="review-empty">还没有读者提问，可以先问一个你关心的问题。</p>
        }
        else
        {
            <div class="qa-list">
                @foreach (var question in Model.Questions)
                {
                    <article class="qa-item">
                        <div class="qa-question">
                            <strong>问</strong>
                            <div>
                                <p>@question.Question</p>
                                <small>@(question.User?.DisplayName ?? question.User?.UserName ?? "读者") · @question.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(question.Answer))
                        {
                            <div class="qa-answer">
                                <strong>答</strong>
                                <div>
                                    <p>@question.Answer</p>
                                    <small>@question.AnsweredBy · @question.AnsweredAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                                </div>
                            </div>
                        }
                        else if (Model.IsAdmin)
                        {
                            <form method="post" asp-page-handler="AnswerQuestion" asp-route-id="@Model.Product.Id" class="qa-answer-form">
                                <input type="hidden" asp-for="Answer.QuestionId" value="@question.Id" />
                                <textarea class="editorial-textarea" asp-for="Answer.Content" maxlength="500" placeholder="填写回答内容"></textarea>
                                <button type="submit" class="primary-button">发布回答</button>
                            </form>
                        }
                        else
                        {
                            <p class="qa-pending">这个问题还在等待回答。</p>
                        }
                    </article>
                }
            </div>
        }
    </section>

    <section class="review-section">
        <div class="section-heading">
            <div>
                <span class="section-kicker">Reviews</span>
                <h2>读者评价</h2>
            </div>
            <div class="review-score">
                <strong>@Model.ReviewSummary.AverageText</strong>
                <span>@Model.ReviewSummary.Count 条评价</span>
            </div>
        </div>

        @if (Model.CanReview)
        {
            <form method="post" enctype="multipart/form-data" asp-page-handler="Review" asp-route-id="@Model.Product.Id" class="review-form">
                <div class="form-grid">
                    <div class="form-field">
                        <label asp-for="Review.Rating"></label>
                        <select class="editorial-select" asp-for="Review.Rating">
                            <option value="5">5 星，很值得</option>
                            <option value="4">4 星，推荐</option>
                            <option value="3">3 星，还可以</option>
                            <option value="2">2 星，一般</option>
                            <option value="1">1 星，不太满意</option>
                        </select>
                    </div>
                    <div class="form-field">
                        <label asp-for="Review.Image"></label>
                        <input class="editorial-input" asp-for="Review.Image" type="file" accept="image/*" />
                        @if (!string.IsNullOrWhiteSpace(Model.UserReview?.ImageUrl))
                        {
                            <small class="review-hint">重新上传会替换当前晒图。</small>
                        }
                    </div>
                </div>
                <div class="form-field">
                    <label asp-for="Review.Content"></label>
                    <textarea class="editorial-textarea" asp-for="Review.Content" maxlength="500" placeholder="写下你的阅读感受"></textarea>
                    <span asp-validation-for="Review.Content" class="field-validation-error"></span>
                </div>
                <button type="submit" class="primary-button">@(Model.UserReview is null ? "发布评价" : "更新评价")</button>
            </form>

            @if (Model.UserReview is not null)
            {
                @if (string.IsNullOrWhiteSpace(Model.UserReview.FollowUpContent))
                {
                    <form method="post" asp-page-handler="FollowUp" asp-route-id="@Model.Product.Id" class="followup-form">
                        <div class="form-field">
                            <label asp-for="FollowUp.Content"></label>
                            <textarea class="editorial-textarea" asp-for="FollowUp.Content" maxlength="500" placeholder="读完一段时间后，补充一点新的感受"></textarea>
                            <span asp-validation-for="FollowUp.Content" class="field-validation-error"></span>
                        </div>
                        <button type="submit" class="secondary-button">发布追评</button>
                    </form>
                }
                else
                {
                    <div class="review-followup self-followup">
                        <strong>你的追评</strong>
                        <p>@Model.UserReview.FollowUpContent</p>
                        <small>@Model.UserReview.FollowUpAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                }
            }
        }
        else if (User.Identity?.IsAuthenticated == true)
        {
            <p class="review-hint">购买后即可评价这本书。</p>
        }
        else
        {
            <p class="review-hint">
                <a asp-page="/Account/Login" class="text-link">登录</a> 后，购买过的图书可以发布评价。
            </p>
        }

        @if (Model.Reviews.Count == 0)
        {
            <p class="review-empty">还没有评价，第一条读后感正在等它的读者。</p>
        }
        else
        {
            <div class="review-list">
                @foreach (var review in Model.Reviews)
                {
                    <article class="review-item">
                        <div class="review-item-head">
                            <strong>@(review.User?.DisplayName ?? review.User?.UserName ?? "读者")</strong>
                            <span>@(new string('★', review.Rating))@(new string('☆', 5 - review.Rating))</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(review.Content))
                        {
                            <p>@review.Content</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(review.ImageUrl))
                        {
                            <img class="review-photo" src="@review.ImageUrl" alt="@(review.User?.DisplayName ?? review.User?.UserName ?? "读者") 的晒图" loading="lazy" />
                        }
                        @if (!string.IsNullOrWhiteSpace(review.FollowUpContent))
                        {
                            <div class="review-followup">
                                <strong>追评</strong>
                                <p>@review.FollowUpContent</p>
                                <small>@review.FollowUpAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                            </div>
                        }
                        <small>@review.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </article>
                }
            </div>
        }
    </section>

    @if (Model.RelatedProducts.Count > 0)
    {
        <section class="product-rail">
            <div class="section-heading">
                <div>
                    <span class="section-kicker">You May Like</span>
                    <h2>同类推荐</h2>
                </div>
                <a asp-page="/Products/Index" asp-route-category="@Model.Product.Category" class="ghost-button">更多 @Model.Product.Category</a>
            </div>
            <div class="compact-book-grid">
                @foreach (var product in Model.RelatedProducts)
                {
                    <a asp-page="/Products/Details" asp-route-id="@product.Id" class="compact-book">
                        <img src="@product.CoverUrl" alt="@product.Title" loading="lazy" />
                        <span>@product.Category</span>
                        <strong>@product.Title</strong>
                        <small>￥@product.Price.ToString("0.00")</small>
                    </a>
                }
            </div>
        </section>
    }

    @if (Model.RecentlyViewedProducts.Count > 0)
    {
        <section class="product-rail">
            <div class="section-heading">
                <div>
                    <span class="section-kicker">History</span>
                    <h2>最近浏览</h2>
                </div>
            </div>
            <div class="compact-book-grid">
                @foreach (var product in Model.RecentlyViewedProducts)
                {
                    <a asp-page="/Products/Details" asp-route-id="@product.Id" class="compact-book">
                        <img src="@product.CoverUrl" alt="@product.Title" loading="lazy" />
                        <span>@product.Author</span>
                        <strong>@product.Title</strong>
                        <small>￥@product.Price.ToString("0.00")</small>
                    </a>
                }
            </div>
        </section>
    }
}

<script>
async function toggleWishlist(productId) {
    var btn = document.getElementById('wishlist-toggle');
    var isWishlisted = btn.innerText.includes('已收藏');
    var url = '/Products/Details/' + productId + '?handler=ToggleWishlist';

    try {
        var response = await fetch(url, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        });
        if (response.ok) {
            var newState = !isWishlisted;
            btn.innerText = newState ? '♥ 已收藏' : '♡ 收藏';
            btn.className = newState ? 'secondary-button' : 'ghost-button';
        }
    } catch (e) {
        window.location.href = url;
    }
}

document.addEventListener('DOMContentLoaded', function () {
    var labels = new Map([
        ['qa-form', { closed: '发布读者问答', opened: '收起读者问答' }],
        ['review-form', { closed: '发布评价', opened: '收起评价' }],
        ['followup-form', { closed: '发布追评', opened: '收起追评' }]
    ]);

    document.querySelectorAll('.qa-form, .review-form, .followup-form').forEach(function (form) {
        var className = Array.from(labels.keys()).find(function (name) {
            return form.classList.contains(name);
        });

        form.classList.add('js-collapsible-form');
        form.dataset.closedLabel = labels.get(className)?.closed || '发布';
        form.dataset.openedLabel = labels.get(className)?.opened || '收起';
        form.dataset.expandLabel = form.dataset.closedLabel;
        form.setAttribute('aria-expanded', 'false');
        form.tabIndex = 0;

        var setExpanded = function (expanded) {
            form.classList.toggle('is-expanded', expanded);
            form.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            form.dataset.expandLabel = expanded ? form.dataset.openedLabel : form.dataset.closedLabel;
        };

        var toggle = function () {
            var nextExpanded = !form.classList.contains('is-expanded');
            setExpanded(nextExpanded);

            var firstField = form.querySelector('textarea, select, input:not([type="hidden"])');
            if (nextExpanded && firstField) {
                firstField.focus();
            }
        };

        form.addEventListener('click', function (event) {
            if (event.target !== form) {
                return;
            }

            toggle();
        });

        form.addEventListener('keydown', function (event) {
            if (event.target !== form) {
                return;
            }

            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                toggle();
            }
        });
    });
});
</script>

<style>
.wishlist-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.75rem;
}

.product-rail,
.review-section,
.qa-section {
    margin-top: 3rem;
}

.review-section,
.qa-section {
    display: grid;
    gap: 1rem;
}

.qa-count {
    color: var(--muted);
    font-size: 0.9rem;
}

.qa-form,
.review-form,
.followup-form {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 253, 249, 0.62);
}

.js-collapsible-form {
    cursor: pointer;
    position: relative;
}

.js-collapsible-form::before {
    content: attr(data-expand-label);
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2.75rem;
    color: var(--ink);
    font-weight: 700;
}

.js-collapsible-form::after {
    content: "+";
    position: absolute;
    right: 1rem;
    top: 1.6rem;
    color: var(--accent);
    font-size: 1.2rem;
    line-height: 1;
}

.js-collapsible-form:not(.is-expanded) > * {
    display: none;
}

.js-collapsible-form.is-expanded::after {
    content: "-";
}

.qa-form button,
.review-form button,
.followup-form button {
    justify-self: start;
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
}

.qa-list,
.review-list {
    display: grid;
    gap: 0.85rem;
}

.qa-item,
.review-item {
    display: grid;
    gap: 0.7rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--line);
}

.qa-item:last-child,
.review-item:last-child {
    border-bottom: 0;
}

.qa-question,
.qa-answer {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 0.75rem;
}

.qa-question > strong,
.qa-answer > strong {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: var(--ink);
    color: #fff8f2;
}

.qa-answer > strong {
    background: var(--accent);
}

.qa-question p,
.qa-answer p,
.review-item p,
.review-followup p {
    margin: 0;
    color: var(--ink);
    line-height: 1.8;
}

.qa-question small,
.qa-answer small,
.review-item small,
.review-score span,
.review-hint,
.review-empty,
.qa-pending {
    color: var(--muted);
}

.qa-answer-form {
    display: grid;
    gap: 0.6rem;
    margin-left: 49px;
}

.qa-answer-form button {
    justify-self: start;
}

.qa-pending {
    margin: 0 0 0 49px;
}

.review-score {
    display: grid;
    justify-items: end;
    gap: 0.25rem;
}

.review-score strong {
    color: var(--accent);
    font-size: 1.8rem;
    line-height: 1;
}

.review-item-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
}

.review-item-head span {
    color: var(--accent);
    letter-spacing: 0;
}

.review-photo {
    width: min(220px, 100%);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--line);
}

.review-followup {
    display: grid;
    gap: 0.35rem;
    padding: 0.8rem;
    border-left: 3px solid var(--accent);
    background: rgba(255, 253, 249, 0.7);
}

.self-followup {
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
}

.product-rail h2 {
    margin: 0.25rem 0 0;
    font-size: 1.35rem;
}

.compact-book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
}

.compact-book {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
}

.compact-book img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 14px 30px rgba(53, 24, 16, 0.12);
}

.compact-book span,
.compact-book small {
    color: var(--muted);
    font-size: 0.85rem;
}

.compact-book strong {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
</style>
