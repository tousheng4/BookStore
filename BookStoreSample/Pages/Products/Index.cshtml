@page
@model BookStoreSample.Pages.Products.IndexModel
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "书店";
    var hasKeyword = !string.IsNullOrWhiteSpace(Model.Keyword);
    var pageNumbers = Enumerable.Range(1, Model.TotalPages)
        .Where(page => page == 1 || page == Model.TotalPages || Math.Abs(page - Model.CurrentPageNumber) <= 2)
        .ToList();
}

<section class="catalog-shell catalog-shell-refined">
    <article class="catalog-hero">
        <div class="catalog-hero-copy">
            <span class="section-kicker">线上书房目录</span>
            <h1 class="catalog-hero-title">书店</h1>
            <p class="catalog-hero-text">从技术、文学到设计与商业，按主题慢慢挑，也可以直接搜索你已经想找的那一本。</p>
        </div>
    </article>

    <section class="catalog-coupon-strip" aria-label="优惠券">
        <div>
            <span class="coupon-strip-kicker">满减券</span>
            <strong>先领券，再挑书</strong>
            <p>新客满 99 减 10，精选图书满 199 减 25，囤书满 299 减 45。</p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="primary-button" asp-page="/Account/Coupons">领取优惠券</a>
        }
        else
        {
            <a class="primary-button" asp-page="/Account/Login" asp-route-returnUrl="/Account/Coupons">登录领券</a>
        }
    </section>

    @if (User.Identity?.IsAuthenticated == true && Model.RecommendedProducts.Count > 0)
    {
        <section class="recommendation-strip" aria-label="猜你喜欢">
            <div class="recommendation-head">
                <div>
                    <h2 class="recommendation-title">猜你喜欢</h2>
                    <p>按你的下单偏好挑了几本</p>
                </div>
                <span class="recommendation-note">同分类、同作者优先</span>
            </div>
            <div class="recommendation-list">
                @foreach (var book in Model.RecommendedProducts)
                {
                    var reviewSummary = Model.ReviewSummaries.TryGetValue(book.Id, out var summary)
                        ? summary
                        : new ReviewSummary(0, 0);
                    <article class="recommendation-item">
                        <a class="recommendation-cover" asp-page="/Products/Details" asp-route-id="@book.Id">
                            <img src="@book.CoverUrl" alt="@book.Title" />
                        </a>
                        <div class="recommendation-body">
                            <span class="recommendation-category">@book.Category</span>
                            <h3><a asp-page="/Products/Details" asp-route-id="@book.Id">@book.Title</a></h3>
                            <p>@book.Author · @book.Publisher</p>
                            <p class="catalog-rating">
                                <span>@(reviewSummary.Count == 0 ? "☆☆☆☆☆" : new string('★', (int)Math.Round(reviewSummary.AverageRating)).PadRight(5, '☆'))</span>
                                @reviewSummary.AverageText
                            </p>
                        </div>
                        <div class="recommendation-actions">
                            <strong>￥@book.Price</strong>
                            <a class="primary-button" asp-page="/Products/Details" asp-route-id="@book.Id">查看</a>
                            <button type="button"
                                    class="ghost-button wishlist-btn @(Model.WishlistedIds.Contains(book.Id) ? "is-wishlisted" : "")"
                                    onclick="toggleWishlist(this, @book.Id)"
                                    data-product-id="@book.Id"
                                    data-wishlisted="@(Model.WishlistedIds.Contains(book.Id) ? "true" : "false")">
                                @(Model.WishlistedIds.Contains(book.Id) ? "♥" : "♡")
                            </button>
                        </div>
                    </article>
                }
            </div>
        </section>
    }

    <section class="catalog-filter-panel" aria-label="筛选目录">
        <div class="filter-panel-head">
            <div>
                <span class="section-kicker">筛选目录</span>
                <h2>按条件找书</h2>
            </div>
            <span>搜索、分类、价格和评价都可以一起用</span>
        </div>
        <form method="get" class="filter-form" role="search">
            <div class="filter-row">
                <input class="filter-input" type="text" asp-for="Keyword" placeholder="输入书名、作者或分类" />
                <select class="filter-input" asp-for="Category">
                    <option value="">全部分类</option>
                    <option value="编程开发">编程开发</option>
                    <option value="人工智能">人工智能</option>
                    <option value="文学小说">文学小说</option>
                    <option value="商业管理">商业管理</option>
                    <option value="设计创意">设计创意</option>
                    <option value="历史人文">历史人文</option>
                    <option value="教材教辅">教材教辅</option>
                </select>
                <select class="filter-input" asp-for="SortBy">
                    <option value="newest">最新上架</option>
                    <option value="price_asc">价格 ↑</option>
                    <option value="price_desc">价格 ↓</option>
                    <option value="sales">销量最高</option>
                    <option value="rating">评分最高</option>
                    <option value="stock">库存最多</option>
                </select>
            </div>
            <div class="filter-row">
                <label class="price-filter-label">价格区间：</label>
                <input class="filter-input price-input" type="number" asp-for="MinPrice" placeholder="最低价" min="0" step="1" />
                <span>—</span>
                <input class="filter-input price-input" type="number" asp-for="MaxPrice" placeholder="最高价" min="0" step="1" />
                <label class="review-filter">
                    <input type="checkbox" asp-for="ReviewedOnly" />
                    只看有评价
                </label>
                <button type="submit" class="primary-button">筛选</button>
                <a asp-page="/Products/Index" class="ghost-button">重置</a>
            </div>
        </form>
    </section>

    <section class="catalog-summary" aria-label="检索结果">
        <div class="catalog-summary-line">
            <span class="catalog-summary-count">共 @Model.TotalCount 本图书</span>
            @if (Model.TotalCount > 0)
            {
                <span class="catalog-summary-range">当前显示 @Model.StartItem - @Model.EndItem</span>
            }
            @if (hasKeyword)
            {
                <span class="catalog-summary-keyword">当前筛选：@Model.Keyword</span>
                <a class="ghost-link" asp-page="/Products/Index">清除筛选</a>
            }
            else
            {
                <a class="catalog-summary-keyword catalog-summary-link" asp-page="/Products/Index">浏览全部目录</a>
            }
        </div>
    </section>

    @if (Model.Products.Count == 0)
    {
        <section class="empty-state catalog-empty">
            <h2 class="catalog-empty-title">没有找到相关图书</h2>
            <p>换一个关键词试试，或者回到完整目录继续浏览。</p>
            <a class="primary-button" asp-page="/Products/Index">查看全部图书</a>
        </section>
    }
    else
    {
        <div class="catalog-list catalog-list-refined">
            @foreach (var book in Model.Products)
            {
                var reviewSummary = Model.ReviewSummaries.TryGetValue(book.Id, out var summary)
                    ? summary
                    : new ReviewSummary(0, 0);
                <article class="catalog-item catalog-item-refined">
                    <a class="catalog-cover-link" asp-page="/Products/Details" asp-route-id="@book.Id">
                        <div class="cover-frame catalog-cover-frame">
                            <img src="@book.CoverUrl" alt="@book.Title" />
                        </div>
                    </a>
                    <div class="catalog-item-body catalog-item-body-refined">
                        <div class="catalog-item-head">
                            <p class="book-tile-meta">@book.Category</p>
                            <p class="catalog-item-stock">库存 @book.Stock</p>
                        </div>
                        <h2 class="catalog-item-title"><a asp-page="/Products/Details" asp-route-id="@book.Id">@book.Title</a></h2>
                        <p class="product-copy catalog-author">@book.Author · @book.Publisher</p>
                        <p class="catalog-rating">
                            <span>@(reviewSummary.Count == 0 ? "☆☆☆☆☆" : new string('★', (int)Math.Round(reviewSummary.AverageRating)).PadRight(5, '☆'))</span>
                            @reviewSummary.AverageText · @reviewSummary.Count 条评价
                        </p>
                        <p class="catalog-description">@book.Description</p>
                    </div>
                    <div class="catalog-item-actions catalog-item-actions-refined">
                        <div class="catalog-price-block">
                            <span class="catalog-price-label">到手价</span>
                            <span class="product-price">￥@book.Price</span>
                        </div>
                        <a class="primary-button" asp-page="/Products/Details" asp-route-id="@book.Id">查看详情</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button type="button"
                                    class="ghost-button wishlist-btn @(Model.WishlistedIds.Contains(book.Id) ? "is-wishlisted" : "")"
                                    onclick="toggleWishlist(this, @book.Id)"
                                    data-product-id="@book.Id"
                                    data-wishlisted="@(Model.WishlistedIds.Contains(book.Id) ? "true" : "false")">
                                @(Model.WishlistedIds.Contains(book.Id) ? "♥" : "♡")
                            </button>
                        }
                    </div>
                </article>
            }
        </div>

        <nav class="pagination-shell" aria-label="图书分页导航">
            <a class="pagination-link @(Model.CurrentPageNumber <= 1 ? "is-disabled" : string.Empty)"
               asp-page="/Products/Index"
               asp-route-keyword="@Model.Keyword"
               asp-route-category="@Model.Category"
               asp-route-minPrice="@Model.MinPrice"
               asp-route-maxPrice="@Model.MaxPrice"
               asp-route-sortBy="@Model.SortBy"
               asp-route-reviewedOnly="@Model.ReviewedOnly"
               asp-route-currentPage="@(Model.CurrentPageNumber - 1)">上一页</a>

            <div class="pagination-pages">
                @for (var i = 0; i < pageNumbers.Count; i++)
                {
                    if (i > 0 && pageNumbers[i] - pageNumbers[i - 1] > 1)
                    {
                        <span class="pagination-ellipsis">…</span>
                    }

                    var pageNumber = pageNumbers[i];
                    <a class="pagination-link @(pageNumber == Model.CurrentPageNumber ? "is-current" : string.Empty)"
                       asp-page="/Products/Index"
                       asp-route-keyword="@Model.Keyword"
                       asp-route-category="@Model.Category"
                       asp-route-minPrice="@Model.MinPrice"
                       asp-route-maxPrice="@Model.MaxPrice"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-reviewedOnly="@Model.ReviewedOnly"
                       asp-route-currentPage="@pageNumber">@pageNumber</a>
                }
            </div>

            <a class="pagination-link @(Model.CurrentPageNumber >= Model.TotalPages ? "is-disabled" : string.Empty)"
               asp-page="/Products/Index"
               asp-route-keyword="@Model.Keyword"
               asp-route-category="@Model.Category"
               asp-route-minPrice="@Model.MinPrice"
               asp-route-maxPrice="@Model.MaxPrice"
               asp-route-sortBy="@Model.SortBy"
               asp-route-reviewedOnly="@Model.ReviewedOnly"
               asp-route-currentPage="@(Model.CurrentPageNumber + 1)">下一页</a>
        </nav>
    }
</section>

<button type="button" class="assistant-fab" id="assistantLauncher" aria-label="打开 AI 选书助手" aria-expanded="false">
    <span class="assistant-robot">
        <span class="robot-antenna"></span>
        <span class="robot-face">
            <i></i>
            <i></i>
        </span>
    </span>
    <span>选书助手</span>
</button>

<section class="assistant-floating-panel" id="assistantPanel" aria-label="AI 选书助手" aria-hidden="true">
    <div class="book-assistant">
        <div class="assistant-head">
            <div>
                <span class="assistant-kicker">AI 选书助手</span>
                <h2>问我想读什么</h2>
            </div>
            <div class="assistant-window-actions">
                <span class="assistant-status">站内书库匹配</span>
                <button type="button" id="assistantClose" aria-label="关闭 AI 选书助手">×</button>
            </div>
        </div>
        <div class="assistant-console">
            <aside class="assistant-history-panel">
                <div class="assistant-history-head">
                    <span>聊天记录</span>
                    <button type="button" id="newAssistantChat">新对话</button>
                </div>
                <div class="assistant-history-list" id="assistantHistoryList"></div>
                <button type="button" class="assistant-clear-button" id="clearAssistantHistory">清空记录</button>
            </aside>
            <div class="assistant-chat-panel">
                <div class="assistant-messages" id="assistantMessages" aria-live="polite">
                    <div class="assistant-message assistant-message-ai">
                        <p>告诉我你的目标、兴趣或预算，我会从当前书店里挑几本合适的书。</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="assistant-prompts" aria-label="快捷问题">
            <button type="button" data-question="我想入门人工智能，有什么书适合新手？">AI 入门</button>
            <button type="button" data-question="推荐几本适合提升编程能力的书">提升编程</button>
            <button type="button" data-question="我想看轻松一点的文学小说">文学小说</button>
        </div>
        <form class="assistant-form" id="assistantForm">
            <input id="assistantQuestion" name="question" type="text" autocomplete="off" placeholder="例如：想学机器学习，预算低一点" />
            <button type="submit" class="primary-button">询问</button>
        </form>
    </div>
</section>

<script>
async function toggleWishlist(btn, productId) {
    var isWishlisted = btn.getAttribute('data-wishlisted') === 'true';
    var url = '/Products/Index?handler=ToggleWishlist&productId=' + productId;

    try {
        var response = await fetch(url, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        });
        if (response.ok) {
            var newState = !isWishlisted;
            btn.setAttribute('data-wishlisted', newState ? 'true' : 'false');
            btn.innerHTML = newState ? '♥' : '♡';
            if (newState) {
                btn.classList.add('is-wishlisted');
            } else {
                btn.classList.remove('is-wishlisted');
            }
        }
    } catch (e) {
        // fallback: treat as SPA redirect
        window.location.href = url;
    }
}

var assistantForm = document.getElementById('assistantForm');
var assistantQuestion = document.getElementById('assistantQuestion');
var assistantMessages = document.getElementById('assistantMessages');
var assistantHistoryList = document.getElementById('assistantHistoryList');
var clearAssistantHistoryButton = document.getElementById('clearAssistantHistory');
var newAssistantChatButton = document.getElementById('newAssistantChat');
var assistantLauncher = document.getElementById('assistantLauncher');
var assistantPanel = document.getElementById('assistantPanel');
var assistantClose = document.getElementById('assistantClose');
var assistantHistoryKey = 'bookstoreAssistantHistory';
var assistantHistory = loadAssistantHistory();
var assistantActiveIndex = assistantHistory.length - 1;

function appendAssistantMessage(text, type) {
    var message = document.createElement('div');
    message.className = 'assistant-message assistant-message-' + type;
    var paragraph = document.createElement('p');
    paragraph.textContent = text;
    message.appendChild(paragraph);
    assistantMessages.appendChild(message);
    assistantMessages.scrollTop = assistantMessages.scrollHeight;
    return message;
}

function appendAssistantSuggestions(suggestions) {
    if (!suggestions || suggestions.length === 0) {
        return;
    }

    var list = document.createElement('div');
    list.className = 'assistant-suggestions';
    suggestions.forEach(function (book) {
        var card = document.createElement('a');
        card.className = 'assistant-suggestion';
        card.href = '/Products/Details/' + book.id;

        var image = document.createElement('img');
        image.src = book.coverUrl || '';
        image.alt = book.title;

        var body = document.createElement('div');
        var category = document.createElement('span');
        category.textContent = book.category;
        var title = document.createElement('strong');
        title.textContent = book.title;
        var meta = document.createElement('small');
        meta.textContent = book.author + ' · ￥' + Number(book.price).toFixed(2);
        var reason = document.createElement('p');
        reason.textContent = book.reason;

        body.appendChild(category);
        body.appendChild(title);
        body.appendChild(meta);
        body.appendChild(reason);
        card.appendChild(image);
        card.appendChild(body);
        list.appendChild(card);
    });
    assistantMessages.appendChild(list);
    assistantMessages.scrollTop = assistantMessages.scrollHeight;
}

function loadAssistantHistory() {
    try {
        return JSON.parse(localStorage.getItem(assistantHistoryKey) || '[]');
    } catch (e) {
        return [];
    }
}

function saveAssistantHistory() {
    localStorage.setItem(assistantHistoryKey, JSON.stringify(assistantHistory.slice(-8)));
}

function renderAssistantWelcome() {
    assistantMessages.innerHTML = '';
    appendAssistantMessage('告诉我你的目标、兴趣或预算，我会从当前书店里挑几本合适的书。', 'ai');
}

function renderAssistantHistoryList() {
    if (!assistantHistoryList) {
        return;
    }

    assistantHistoryList.innerHTML = '';
    if (assistantHistory.length === 0) {
        var empty = document.createElement('div');
        empty.className = 'assistant-history-empty';
        empty.textContent = '暂无聊天';
        assistantHistoryList.appendChild(empty);
        return;
    }

    assistantHistory.forEach(function (entry, index) {
        var item = document.createElement('button');
        item.type = 'button';
        item.className = 'assistant-history-item' + (index === assistantActiveIndex ? ' is-active' : '');
        item.textContent = entry.question;
        item.addEventListener('click', function () {
            assistantActiveIndex = index;
            renderAssistantTurn(entry);
            renderAssistantHistoryList();
        });
        assistantHistoryList.appendChild(item);
    });
}

function renderAssistantTurn(entry) {
    assistantMessages.innerHTML = '';
    appendAssistantMessage(entry.question, 'user');
    appendAssistantMessage(entry.answer, 'ai');
    appendAssistantSuggestions(entry.suggestions);
}

function renderAssistantHistory() {
    if (!assistantMessages) {
        return;
    }

    renderAssistantHistoryList();
    if (assistantHistory.length === 0) {
        renderAssistantWelcome();
        return;
    }

    assistantActiveIndex = Math.max(0, Math.min(assistantActiveIndex, assistantHistory.length - 1));
    renderAssistantTurn(assistantHistory[assistantActiveIndex]);
}

function rememberAssistantTurn(question, answer, suggestions) {
    assistantHistory.push({
        question: question,
        answer: answer,
        suggestions: suggestions || []
    });
    assistantHistory = assistantHistory.slice(-8);
    assistantActiveIndex = assistantHistory.length - 1;
    saveAssistantHistory();
    renderAssistantHistoryList();
}

async function askBookAssistant(question) {
    var trimmedQuestion = (question || '').trim();
    if (!trimmedQuestion) {
        assistantQuestion.focus();
        return;
    }

    openAssistantPanel();
    appendAssistantMessage(trimmedQuestion, 'user');
    assistantQuestion.value = '';
    var loadingMessage = appendAssistantMessage('正在从书库里帮你挑书...', 'ai');

    try {
        var body = new URLSearchParams();
        body.append('question', trimmedQuestion);
        var response = await fetch('/Products/Index?handler=AskAssistant', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: body.toString()
        });

        if (!response.ok) {
            throw new Error('request failed');
        }

        var result = await response.json();
        loadingMessage.querySelector('p').textContent = result.message;
        appendAssistantSuggestions(result.suggestions);
        rememberAssistantTurn(trimmedQuestion, result.message, result.suggestions);
    } catch (e) {
        var failedMessage = '刚才没能连上选书助手，请稍后再试。';
        loadingMessage.querySelector('p').textContent = failedMessage;
        rememberAssistantTurn(trimmedQuestion, failedMessage, []);
    }
}

function openAssistantPanel() {
    if (!assistantPanel || !assistantLauncher) {
        return;
    }

    assistantPanel.classList.add('is-open');
    assistantPanel.setAttribute('aria-hidden', 'false');
    assistantLauncher.setAttribute('aria-expanded', 'true');
}

function closeAssistantPanel() {
    if (!assistantPanel || !assistantLauncher) {
        return;
    }

    assistantPanel.classList.remove('is-open');
    assistantPanel.setAttribute('aria-hidden', 'true');
    assistantLauncher.setAttribute('aria-expanded', 'false');
}

renderAssistantHistory();

if (assistantForm) {
    assistantForm.addEventListener('submit', function (event) {
        event.preventDefault();
        askBookAssistant(assistantQuestion.value);
    });
}

document.querySelectorAll('.assistant-prompts button').forEach(function (button) {
    button.addEventListener('click', function () {
        askBookAssistant(button.getAttribute('data-question'));
    });
});

if (clearAssistantHistoryButton) {
    clearAssistantHistoryButton.addEventListener('click', function () {
        assistantHistory = [];
        assistantActiveIndex = -1;
        saveAssistantHistory();
        renderAssistantHistoryList();
        renderAssistantWelcome();
    });
}

if (newAssistantChatButton) {
    newAssistantChatButton.addEventListener('click', function () {
        assistantActiveIndex = -1;
        renderAssistantHistoryList();
        renderAssistantWelcome();
        assistantQuestion.focus();
    });
}

if (assistantLauncher) {
    assistantLauncher.addEventListener('click', function () {
        if (assistantPanel?.classList.contains('is-open')) {
            closeAssistantPanel();
        } else {
            openAssistantPanel();
            assistantQuestion?.focus();
        }
    });
}

if (assistantClose) {
    assistantClose.addEventListener('click', closeAssistantPanel);
}
</script>

<style>
.catalog-hero { grid-template-columns: 1fr; }
.assistant-fab {
    position: fixed;
    right: 26px;
    bottom: 28px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(141, 43, 39, 0.22);
    border-radius: 999px;
    padding: 0.55rem 0.85rem 0.55rem 0.55rem;
    background: rgba(255, 251, 245, 0.95);
    color: var(--ink);
    box-shadow: 0 18px 46px rgba(53, 24, 16, 0.2);
}
.assistant-fab:hover {
    color: var(--accent);
    transform: translateY(-2px);
}
.assistant-robot {
    position: relative;
    width: 42px;
    height: 42px;
    display: inline-grid;
    place-items: center;
}
.robot-antenna {
    position: absolute;
    top: 0;
    width: 2px;
    height: 8px;
    background: var(--accent);
}
.robot-antenna::before {
    content: "";
    position: absolute;
    top: -4px;
    left: 50%;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateX(-50%);
}
.robot-face {
    width: 36px;
    height: 30px;
    margin-top: 8px;
    border: 2px solid var(--ink);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    background: var(--paper-deep);
}
.robot-face i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
}
.assistant-floating-panel {
    position: fixed;
    right: 26px;
    bottom: 92px;
    z-index: 59;
    width: min(720px, calc(100vw - 36px));
    max-height: min(680px, calc(100vh - 128px));
    display: none;
}
.assistant-floating-panel.is-open {
    display: block;
}
.book-assistant {
    display: grid;
    gap: 0.8rem;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 253, 249, 0.97);
    box-shadow: 0 22px 70px rgba(53, 24, 16, 0.22);
